<script>
const DB_URL = "https://taschenrechner-mottowoche-default-rtdb.europe-west1.firebasedatabase.app/";

let bucket = null;
let dispMode = 0;
let pickMode = 1;
let expr = '0';
let isCustomText = false;
let result = '—';
let pollTimer = null;
let lastExpr = '';
let lastResult = '';
let isBusy = false;
let needsUpdate = false;
let idleTimer = null;
let idleActive = false;
let bingMuted = false;

// 67 mode state
let mode67Active = false;
let mode67AutoStopTimer = null;
let mode67Interval = null;
let audioCtx = null;
let mode67AudioNodes = [];
let last67Timestamp = 0;

// ─── AUDIO CONTEXT (Web Audio API) ────────────
function getAudioCtx() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();
  return audioCtx;
}

// Generates the 10-second 67 alarm sound
function play67Sound() {
  const s = document.getElementById('snd-67');
  if (!s) return;
  s.currentTime = 0;
  s.play().catch(() => {});
}

function stop67Sound() {
  const s = document.getElementById('snd-67');
  if (!s) return;
  s.pause();
  s.currentTime = 0;
}

// ─── 67 MODE: CONTROLLER ───────────────────────
function trigger67() {
  if (!bucket) return;
  const ts        = Date.now();
  const startAt   = ts + 2000; // beide iPads starten in genau 2 Sek
  mode67Active    = true;
  document.getElementById('btn-67').classList.add('firing');
  pushData({ mode67: ts, mode67stop: false, mode67startAt: startAt });
}

function hardStop67() {
  clearTimeout(mode67AutoStopTimer);
  mode67Active = false;
  document.getElementById('btn-67').classList.remove('firing');
  if (bucket) pushRaw({ mode67: 0, mode67stop: true });
}

// ─── 67 MODE: DISPLAY ─────────────────────────
let local67Timestamp = 0;
let local67Stopped = false;
let local67AutoStop = null;
let local67StartAt   = 0; // ← NEU

function handle67StateChange(ts, stopped, startAt) {
  if (stopped || ts === 0) {
    if (mode67Active) stopMode67Display();
    return;
  }
  if (ts !== local67Timestamp) {
    local67Timestamp = ts;
    local67StartAt   = startAt || (Date.now() + 500); // ← NEU
    startMode67Display();
  }
}

function startMode67Display() {
  if (mode67Active) stopMode67Display();
  mode67Active = true;

  // Hide normal content
  const exprEl = document.getElementById('disp-expr');
  const resEl  = document.getElementById('disp-result');
  const subEl  = document.getElementById('lcd-sub');
  if (exprEl) exprEl.style.opacity = '0';
  if (resEl)  resEl.style.opacity  = '0';
  if (subEl)  subEl.style.opacity  = '0';
  stopMatrix(); // stop idle matrix

  // Start 67 canvas
  const canvas = document.getElementById('matrix-67-canvas');
  canvas.width  = canvas.offsetWidth;
  canvas.height = canvas.offsetHeight;
  canvas.style.opacity = '1';

  const ctx67 = canvas.getContext('2d');
  const tokens = ['6','7','67','6','7','67','6','7']; // weighted towards 6 and 7
  const fontSize = 22;
  const cols = Math.floor(canvas.width / fontSize);
  const drops = Array.from({length: cols}, () => Math.random() * -50);

  // Color matches the display mode
  const color = dispMode === 2 ? '#ffb830' : '#39ff5a';
  const shadowColor = dispMode === 2 ? 'rgba(255,184,48,0.8)' : 'rgba(57,255,90,0.8)';

  mode67Interval = setInterval(() => {
    if (!mode67Active) return;

    ctx67.fillStyle = dispMode === 2
      ? 'rgba(16, 10, 0, 0.15)'
      : 'rgba(6, 16, 6, 0.15)';
    ctx67.fillRect(0, 0, canvas.width, canvas.height);

    ctx67.font = `bold ${fontSize}px 'Orbitron', monospace`;
    ctx67.shadowBlur = 8;
    ctx67.shadowColor = shadowColor;

    for (let i = 0; i < drops.length; i++) {
      const tok = tokens[Math.floor(Math.random() * tokens.length)];
      // Brighter lead character
      ctx67.fillStyle = '#ffffff';
      ctx67.fillText(tok, i * fontSize, drops[i] * fontSize);

      // Normal color for rest
      ctx67.fillStyle = color;

      drops[i] += 0.6;
      if (drops[i] * fontSize > canvas.height && Math.random() > 0.96) {
        drops[i] = -5;
      }
    }
    ctx67.shadowBlur = 0;
  }, 40);

  // Play sound
    const snd = document.getElementById('snd-67');
  if (snd) {
    snd.onended     = () => stopMode67Display();
    snd.currentTime = 0;
    const delay = Math.max(0, local67StartAt - Date.now());
    setTimeout(() => {
      if (mode67Active) snd.play().catch(() => {});
    }, delay);
  }
}

function stopMode67Display() {
  mode67Active = false;
  clearTimeout(local67AutoStop);
  clearInterval(mode67Interval);
  stop67Sound();

  const canvas = document.getElementById('matrix-67-canvas');
  canvas.style.opacity = '0';
  setTimeout(() => {
    const ctx67 = canvas.getContext('2d');
    ctx67.clearRect(0, 0, canvas.width, canvas.height);
  }, 350);

  // Restore normal content
  const exprEl = document.getElementById('disp-expr');
  const resEl  = document.getElementById('disp-result');
  const subEl  = document.getElementById('lcd-sub');
  if (exprEl) exprEl.style.opacity = '1';
  if (resEl)  resEl.style.opacity  = '1';
  if (subEl)  subEl.style.opacity  = '1';

  resetIdle();
}

// ─── SETUP ────────────────────────────────────
function pickDisp(n) {
  pickMode = n;
  document.getElementById('pick1').classList.toggle('active', n===1);
  document.getElementById('pick2').classList.toggle('active', n===2);
}

async function createRoom() {
  const btn = document.getElementById('btn-create');
  const loading = document.getElementById('setup-loading');
  btn.disabled = true;
  loading.textContent = 'VERBINDE...';
  bucket = 'R' + Math.floor(1000 + Math.random() * 9000);
  try {
    await push('0', '—');
    startController();
  } catch (err) {
    loading.textContent = '';
    document.getElementById('setup-error').textContent = 'FEHLER - Firebase Link prüfen!';
    btn.disabled = false;
  }
}

function joinDisplay() {
  const code = document.getElementById('code-input').value.trim();
  if (code.length < 3) { document.getElementById('setup-error').textContent = 'Code zu kurz'; return; }
  bucket = code;
  dispMode = pickMode;

  const s1 = document.getElementById('snd-click');
  const s2 = document.getElementById('snd-bing');
  if(s1) s1.play().then(() => { s1.pause(); s1.currentTime = 0; }).catch(()=>{});
  if(s2) s2.play().then(() => { s2.pause(); s2.currentTime = 0; }).catch(()=>{});

  // Unlock Web Audio on user gesture
  getAudioCtx();

  const el = document.documentElement;
  const rfs = el.requestFullscreen || el.webkitRequestFullscreen || el.msRequestFullscreen;
  if (rfs) rfs.call(el).catch(()=>{});

  startDisplay();
}

// ─── CONTROLLER ───────────────────────────────
function startController() {
  show('ctrl');
  document.getElementById('ctrl-room').textContent = 'ROOM: ' + bucket;
}

function p(btn) {
  isCustomText = false;
  if (btn === 'C') { expr = '0'; result = '—'; }
  else if (btn === '⌫') { expr = expr.length > 1 ? expr.slice(0,-1) : '0'; }
  else if (btn === '=') {
    try {
      let e = expr.replace(/÷/g,'/').replace(/×/g,'*').replace(/−/g,'-').replace(/,/g,'.');
      let r = Function('"use strict";return (' + e + ')')();
      result = Number.isInteger(r) ? String(r) : parseFloat(r.toFixed(10)).toString().replace('.',',');
    } catch { result = 'ERROR'; }
  } else if (btn === '±') {
    expr = expr.startsWith('-') ? expr.slice(1) : (expr!=='0' ? '-'+expr : '0');
  } else if (btn === '%') {
    try {
      let e = expr.replace(/÷/g,'/').replace(/×/g,'*').replace(/−/g,'-').replace(/,/g,'.');
      let r = Function('"use strict";return (' + e + ')')() / 100;
      expr = String(r).replace('.',',');
      p('=');
    } catch { result = 'ERROR'; }
  } else {
    if (expr === '0' && /\d/.test(btn)) expr = btn;
    else expr += btn;
  }
  document.getElementById('ctrl-expr').textContent = expr;
  document.getElementById('ctrl-result').textContent = result;
  push(expr, result);
}

function sendText() {
  const t = document.getElementById('custom-in').value.trim();
  if (!t) return;
  isCustomText = true;
  let mid = Math.floor(t.length / 2);
  let splitIndex = t.indexOf(' ', mid);
  if (splitIndex === -1) splitIndex = mid;
  let part1 = t.substring(0, splitIndex).trim();
  let part2 = t.substring(splitIndex).trim();
  expr = part1; result = part2;
  document.getElementById('ctrl-expr').textContent = part1;
  document.getElementById('ctrl-result').textContent = part2;
  document.getElementById('custom-in').value = '';
  push(part1, part2);
  setTimeout(() => { isCustomText = false; }, 1000);
}

async function push(e, r) {
  if (isBusy) { needsUpdate = true; return; }
  isBusy = true;
  needsUpdate = false;
  try {
    await fetch(`${DB_URL}${bucket}.json`, {
      method: 'PATCH',
      body: JSON.stringify({ expr: e, result: r, custom: isCustomText })
    });
    setDot('live');
  } catch { setDot('err'); }
  finally {
    isBusy = false;
    if (needsUpdate) push(expr, result);
  }
}

async function pushRaw(obj) {
  try {
    await fetch(`${DB_URL}${bucket}.json`, {
      method: 'PATCH',
      body: JSON.stringify(obj)
    });
    setDot('live');
  } catch { setDot('err'); }
}

function setDot(s) {
  const dot = document.getElementById('dot');
  if (!dot) return;
  dot.style.background = s==='live' ? 'var(--green)' : (s==='err' ? '#ff4444' : 'var(--green-dim)');
  dot.style.boxShadow = s==='live' ? '0 0 6px var(--green)' : 'none';
}

// ─── DISPLAY ──────────────────────────────────
function startDisplay() {
  show('display');
  const isResult = dispMode === 2;
  document.getElementById('disp-expr').classList.toggle('hidden', isResult);
  document.getElementById('disp-result').classList.toggle('hidden', !isResult);
  document.getElementById('disp-brand').textContent = isResult
    ? 'CASIO · fx-9750GIII · ERGEBNIS'
    : 'CASIO · fx-9750GIII · EINGABE';
  pollDisplay();
  resetIdle();
}

async function pollDisplay() {
  if (!bucket) return;
  try {
    const res = await fetch(`${DB_URL}${bucket}.json`);
    const data = await res.json();
    if (data) {
  isCustomText = data.custom || false;

  // ← HIER, außerhalb aller if-Blöcke:
  bingMuted = data.bingMuted || false;
  const btn = document.getElementById('btn-bingmute');
  if (btn) {
    btn.textContent = bingMuted ? '🔕 BLING: AUS' : '🔔 BLING: AN';
    btn.style.color = bingMuted ? 'var(--red-fn)' : 'var(--green-dim)';
  }

  // ... rest bleibt gleich
      // ── 67 MODE check ──
     handle67StateChange(data.mode67 || 0, data.mode67stop || false, data.mode67startAt || 0);

      // Normal display update (skip if 67 mode is running)
      if (!mode67Active) {
        const val  = dispMode === 1 ? data.expr : data.result;
        const last = dispMode === 1 ? lastExpr : lastResult;
        if (val !== undefined && val !== last) {
          if (dispMode === 1) { lastExpr = val; updateExprDisplay(val); }
          else { lastResult = val; updateResultDisplay(val); }
          document.getElementById('disp-status').textContent = 'LIVE ●';
          document.getElementById('disp-dot').style.background = 'var(--green)';
        }
      }
    }
  } catch {
    document.getElementById('disp-status').textContent = 'OFFLINE ○';
    document.getElementById('disp-dot').style.background = '#ff4444';
  } finally {
    pollTimer = setTimeout(pollDisplay, 500);
  }
}

let typingTimer = null;
function manageTypingSound(start) {
  const s = document.getElementById('snd-click');
  if (!s) return;
  if (start) {
    if (lastExpr === '0') { s.pause(); s.currentTime = 0; return; }
    if (s.paused) s.play().catch(()=>{});
    clearTimeout(typingTimer);
    typingTimer = setTimeout(() => {
      s.pause();
      if (s.currentTime >= s.duration - 0.1) s.currentTime = 0;
    }, 1500);
  }
}
document.getElementById('snd-click').onended = function() { this.currentTime = 0; this.pause(); };

function playBing() {
  if (bingMuted) return; // ← NEU
  const s = document.getElementById('snd-bing');
  if (s) { s.currentTime = 0; s.play().catch(() => {}); }
}

function updateExprDisplay(v) {
  idleActive = false; resetIdle();
  const el = document.getElementById('disp-expr');
  if (dispMode === 1 && !isCustomText && v !== '0') manageTypingSound(true);
  else if (v === '0' || isCustomText) { const s = document.getElementById('snd-click'); if(s){s.pause();s.currentTime=0;} }
  el.style.opacity = '1';
  el.innerHTML = v + '<span class="cursor-blink">_</span>';
}

function updateResultDisplay(v) {
  idleActive = false; resetIdle();
  const el = document.getElementById('disp-result');
  if (dispMode === 2 && !isCustomText && v !== '—') playBing();
  el.innerHTML = `<span class="eq-prefix">=</span><span id="result-val">${v}</span>`;
}

function toggleBingMute() {
  bingMuted = !bingMuted;
  const btn = document.getElementById('btn-bingmute');
  btn.textContent = bingMuted ? '🔕 BLING: AUS' : '🔔 BLING: AN';
  btn.style.color = bingMuted ? 'var(--red-fn)' : 'var(--green-dim)';
  pushRaw({ bingMuted });
}

// ─── IDLE MATRIX ───
let matrixInterval = null;
const matrixCanvas = document.getElementById('matrix-canvas'); // Variable umbenannt!
const matrixCtx = matrixCanvas ? matrixCanvas.getContext('2d') : null; // Variable umbenannt!

function resetIdle() {
  idleActive = false;
  clearTimeout(idleTimer);
  stopMatrix();
  idleTimer = setTimeout(() => { startMatrix(); }, 20000);
}

function startMatrix() {
  if (idleActive || mode67Active || !matrixCanvas) return;
  idleActive = true;
  matrixCanvas.style.opacity = "0.6";
  document.getElementById('disp-expr').style.opacity = "0";
  document.getElementById('disp-result').style.opacity = "0";
  matrixCanvas.width = matrixCanvas.offsetWidth;
  matrixCanvas.height = matrixCanvas.offsetHeight;
  const chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ$+-*/=%";
  const fontSize = 16;
  const columns = matrixCanvas.width / fontSize;
  const drops = [];
  for (let x = 0; x < columns; x++) drops[x] = 1;

  function draw() {
    if (!idleActive) return;
    matrixCtx.fillStyle = "rgba(6, 16, 6, 0.1)";
    matrixCtx.fillRect(0, 0, matrixCanvas.width, matrixCanvas.height);
    matrixCtx.fillStyle = dispMode === 2 ? "#ffb830" : "#39ff5a";
    matrixCtx.font = fontSize + "px 'Share Tech Mono'";
    for (let i = 0; i < drops.length; i++) {
      matrixCtx.fillText(chars.charAt(Math.floor(Math.random() * chars.length)), i * fontSize, drops[i] * fontSize);
      if (drops[i] * fontSize > matrixCanvas.height && Math.random() > 0.975) drops[i] = 0;
      drops[i]++;
    }
  }
  matrixInterval = setInterval(draw, 33);
}

function stopMatrix() {
  clearInterval(matrixInterval);
  if (matrixCanvas) matrixCanvas.style.opacity = "0";
  const exprEl = document.getElementById('disp-expr');
  const resEl = document.getElementById('disp-result');
  if (exprEl) exprEl.style.opacity = "1";
  if (resEl) resEl.style.opacity = "1";
  if (matrixCtx) matrixCtx.clearRect(0, 0, matrixCanvas.width, matrixCanvas.height);
}

// ─── SHARE ────────────────────────────────────
function openShare() {
  const base = location.origin + location.pathname;
  document.getElementById('share-code1').textContent = bucket;
  document.getElementById('share-code2').textContent = bucket;
  document.getElementById('qr1').src = `https://api.qrserver.com/v1/create-qr-code/?size=120x120&color=000000&bgcolor=ffffff&data=${encodeURIComponent(base+'?room='+bucket+'&mode=1')}`;
  document.getElementById('qr2').src = `https://api.qrserver.com/v1/create-qr-code/?size=120x120&color=000000&bgcolor=ffffff&data=${encodeURIComponent(base+'?room='+bucket+'&mode=2')}`;
  document.getElementById('share-overlay').classList.remove('hidden');
}
function closeShare() { document.getElementById('share-overlay').classList.add('hidden'); }

// ─── UTILS ────────────────────────────────────
function show(id) {
  ['setup','ctrl','display'].forEach(s => {
    document.getElementById(s).classList.toggle('hidden', s !== id);
  });
}

// Audio unlock on first click
let audioUnlocked = false;
document.addEventListener('click', () => {
  if (audioUnlocked) return;
  const c = document.getElementById('snd-click');
  const b = document.getElementById('snd-bing');
  const s67 = document.getElementById('snd-67'); // ← NEU
  if (c) c.play().then(() => c.pause()).catch(()=>{});
  if (b) b.play().then(() => b.pause()).catch(()=>{});
  if (s67) s67.play().then(() => s67.pause()).catch(()=>{}); // ← NEU
  try { getAudioCtx(); } catch(_) {}
  audioUnlocked = true;
});

// Auto-start from QR URL
(function() {
  const p = new URLSearchParams(location.search);
  const room = p.get('room');
  const mode = parseInt(p.get('mode'));
  if (room && (mode === 1 || mode === 2)) {
    bucket = room;
    dispMode = mode;
    startDisplay();
  }
})();
</script>
