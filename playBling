<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Taschenrechner Kostüm v3</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&display=swap');

:root {
  --bg: #080c08;
  --panel: #111811;
  --display-bg: #061006;
  --green: #39ff5a;
  --green-mid: #22cc3a;
  --green-dim: #0d4a18;
  --green-glow: rgba(57,255,90,0.25);
  --amber: #ffb830;
  --blue-op: #4fc3f7;
  --red-fn: #ff6b6b;
  --btn: #141a14;
  --btn-border: #1e2a1e;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body { background: var(--bg); color: var(--green); font-family: 'Share Tech Mono', monospace; min-height: 100vh; overflow: hidden; }

.screen { position: fixed; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; transition: opacity 0.3s; }
.screen.hidden { opacity: 0; pointer-events: none; }
#disp-expr.hidden, #disp-result.hidden { display: none !important; }

/* ─── SETUP ─── */
#setup { gap: 14px; }
.logo { font-family: 'Orbitron', monospace; font-size: 11px; letter-spacing: 5px; color: var(--green-dim); margin-bottom: 4px; }
.big-card { background: var(--panel); border: 1px solid var(--btn-border); border-radius: 12px; padding: 20px; width: 100%; max-width: 340px; }
.card-label { font-size: 9px; letter-spacing: 4px; color: var(--green-dim); text-transform: uppercase; margin-bottom: 12px; }
.pill-btn { width: 100%; background: var(--green-dim); border: 1px solid var(--green-mid); color: var(--green); font-family: 'Orbitron', monospace; font-size: 12px; letter-spacing: 3px; padding: 14px; border-radius: 8px; cursor: pointer; margin-bottom: 8px; transition: all 0.1s; }
.pill-btn:active { opacity: 0.6; transform: scale(0.97); }
.pill-btn:disabled { opacity: 0.4; }
.room-input { width: 100%; background: var(--btn); border: 1px solid var(--btn-border); color: var(--green); font-family: 'Orbitron', monospace; font-size: 20px; padding: 12px; border-radius: 8px; text-align: center; letter-spacing: 5px; outline: none; margin-bottom: 10px; }
.room-input::placeholder { color: var(--green-dim); letter-spacing: 3px; font-size: 14px; }

.disp-picker { display: flex; gap: 8px; margin-bottom: 10px; }
.disp-pick-btn { flex: 1; background: var(--btn); border: 2px solid var(--btn-border); color: var(--green-dim); font-family: 'Orbitron', monospace; font-size: 10px; letter-spacing: 2px; padding: 10px 4px; border-radius: 8px; cursor: pointer; transition: all 0.1s; text-align: center; }
.disp-pick-btn.active { border-color: var(--green-mid); color: var(--green); background: var(--green-dim); }

#setup-error { font-size: 10px; color: var(--red-fn); letter-spacing: 2px; text-align: center; min-height: 16px; }
#setup-loading { font-size: 10px; letter-spacing: 3px; color: var(--green-dim); text-align: center; min-height: 16px; }

/* ─── CONTROLLER ─── */
#ctrl { justify-content: flex-start; padding: 10px 12px 8px; gap: 0; overflow-y: auto; max-width: 420px; margin: 0 auto; width: 100%; }
.ctrl-topbar { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 0 0 6px 0; font-size: 9px; letter-spacing: 3px; color: var(--green-dim); }
.status-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green-dim); display: inline-block; margin-right: 5px; transition: background 0.3s; }
.status-dot.live { background: var(--green); box-shadow: 0 0 6px var(--green); }
.share-pill { background: none; border: 1px solid var(--btn-border); color: var(--green-dim); font-family: 'Orbitron', monospace; font-size: 8px; letter-spacing: 2px; padding: 4px 10px; border-radius: 20px; cursor: pointer; }

.ctrl-dual { display: flex; gap: 6px; width: 100%; margin-bottom: 8px; }
.ctrl-disp-wrap { flex: 1; background: var(--display-bg); border: 2px solid var(--green-dim); border-radius: 7px; padding: 6px 10px; }
.ctrl-disp-label { font-size: 8px; letter-spacing: 3px; color: var(--green-dim); margin-bottom: 2px; }
.ctrl-disp-val { font-family: 'Orbitron', monospace; font-size: clamp(16px, 5vw, 26px); color: var(--green); text-shadow: 0 0 8px var(--green-glow); text-align: right; min-height: 1.2em; word-break: break-all; }
.ctrl-disp-val.result { color: var(--amber); text-shadow: 0 0 8px rgba(255,184,48,0.3); }

.calc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; width: 100%; margin-bottom: 8px; }
.c-btn { background: var(--btn); border: 1px solid var(--btn-border); color: var(--green); font-family: 'Orbitron', monospace; font-size: clamp(14px, 4.5vw, 22px); padding: 14px 0; border-radius: 7px; cursor: pointer; transition: all 0.08s; user-select: none; }
.c-btn:active { background: var(--green-dim); box-shadow: 0 0 12px var(--green-glow); transform: scale(0.93); }
.c-btn.op { color: var(--blue-op); }
.c-btn.fn { color: var(--red-fn); }
.c-btn.eq { background: var(--green-dim); color: var(--green); box-shadow: 0 0 10px var(--green-glow); }

/* ── 67 MODE row ── */
.mode67-row { display: flex; gap: 6px; width: 100%; margin-bottom: 8px; }

.btn-67 {
  flex: 2;
  background: linear-gradient(135deg, #1a0a00, #3d1500);
  border: 2px solid var(--amber);
  color: var(--amber);
  font-family: 'Orbitron', monospace;
  font-size: clamp(15px, 5vw, 22px);
  font-weight: 900;
  letter-spacing: 3px;
  padding: 14px 0;
  border-radius: 7px;
  cursor: pointer;
  text-shadow: 0 0 10px var(--amber);
  box-shadow: 0 0 14px rgba(255,184,48,0.25);
  transition: all 0.08s;
  user-select: none;
}
.btn-67:active { transform: scale(0.93); box-shadow: 0 0 28px rgba(255,184,48,0.6); }
.btn-67.firing {
  animation: amber-pulse 0.4s ease-in-out infinite alternate;
}
@keyframes amber-pulse {
  from { box-shadow: 0 0 14px rgba(255,184,48,0.3); border-color: var(--amber); }
  to   { box-shadow: 0 0 40px rgba(255,184,48,0.9); border-color: #ffe080; }
}

.btn-hardstop {
  flex: 1;
  background: linear-gradient(135deg, #1a0000, #3d0000);
  border: 2px solid var(--red-fn);
  color: var(--red-fn);
  font-family: 'Orbitron', monospace;
  font-size: 11px;
  letter-spacing: 2px;
  padding: 14px 6px;
  border-radius: 7px;
  cursor: pointer;
  text-shadow: 0 0 8px rgba(255,107,107,0.5);
  transition: all 0.08s;
  user-select: none;
}
.btn-hardstop:active { transform: scale(0.93); background: #3d0000; }

.custom-row { display: flex; gap: 6px; width: 100%; }
.custom-in { flex: 1; background: var(--btn); border: 1px solid var(--btn-border); color: var(--green); font-family: 'Share Tech Mono', monospace; font-size: 15px; padding: 11px 10px; border-radius: 7px; outline: none; }
.custom-in::placeholder { color: var(--green-dim); }
.send-btn { background: var(--green-dim); border: 1px solid var(--green-mid); color: var(--green); font-family: 'Orbitron', monospace; font-size: 10px; letter-spacing: 2px; padding: 11px 12px; border-radius: 7px; cursor: pointer; white-space: nowrap; }
.send-btn:active { opacity: 0.6; }

/* ─── SHARE OVERLAY ─── */
#share-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.93); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; z-index: 100; padding: 20px; }
#share-overlay.hidden { display: none; }
.share-box { background: var(--panel); border: 1px solid var(--btn-border); border-radius: 14px; padding: 20px; width: 100%; max-width: 320px; text-align: center; }
.qr-wrap { background: white; border-radius: 8px; padding: 8px; display: inline-block; margin: 0 auto 12px; }
.room-code-big { font-family: 'Orbitron', monospace; font-size: 26px; letter-spacing: 6px; color: var(--green); text-shadow: 0 0 16px var(--green-glow); padding: 6px 0; }
.close-share { background: none; border: 1px solid var(--btn-border); color: var(--green-dim); font-family: 'Share Tech Mono', monospace; font-size: 12px; letter-spacing: 2px; padding: 10px 30px; border-radius: 20px; cursor: pointer; }
.share-tabs { display: flex; gap: 8px; width: 100%; max-width: 320px; }
.share-tab { flex: 1; background: var(--panel); border: 1px solid var(--btn-border); border-radius: 10px; padding: 14px 8px; text-align: center; }
.share-tab-label { font-size: 8px; letter-spacing: 3px; color: var(--green-dim); margin-bottom: 6px; }

/* ─── DISPLAY ─── */
#display { background: var(--bg); }

.lcd-outer {
  width: 95vw;
  height: 250px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--display-bg);
  border: 3px solid #0d2a14;
  border-radius: 10px;
  padding: 20px;
  box-sizing: border-box;
  position: relative;
  box-shadow: 0 0 60px rgba(57,255,90,0.1), inset 0 0 30px rgba(0,0,0,0.6);
}
.lcd-outer::after { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.06) 3px, rgba(0,0,0,0.06) 4px); pointer-events: none; border-radius: 8px; }
.lcd-sub { font-size: 10px; letter-spacing: 4px; color: var(--green-dim); margin-bottom: 16px; font-family: 'Share Tech Mono', monospace; }
.lcd-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 16px; font-size: 10px; letter-spacing: 3px; color: var(--green-dim); }

#disp-expr {
  font-family: 'Orbitron', monospace;
  font-weight: 700;
  color: var(--green);
  text-align: right;
  text-shadow: 0 0 20px var(--green);
  letter-spacing: 2px;
  font-size: clamp(20px, 8vw, 90px);
  display: block;
  width: 100%;
  height: 1.2em;
  line-height: 1.2em;
  white-space: nowrap;
  overflow: hidden;
}
#disp-result {
  font-family: 'Orbitron', monospace;
  font-weight: 900;
  color: var(--amber);
  text-align: left;
  text-shadow: 0 0 24px var(--amber);
  letter-spacing: 4px;
  padding-left: 10px;
  font-size: clamp(20px, 8vw, 90px);
  display: block;
  width: 100%;
  height: 1.2em;
  line-height: 1.2em;
  white-space: nowrap;
  overflow: hidden;
}

.eq-prefix { color: var(--green-dim); font-size: 0.55em; vertical-align: middle; margin-right: 8px; }
.brand-row { font-family: 'Orbitron', monospace; font-size: 10px; letter-spacing: 8px; color: var(--green-dim); text-transform: uppercase; margin-bottom: 12px; }

@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
.cursor-blink { animation: blink 1s step-end infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.3;transform:scale(0.8)} }
.live-pulse { animation: pulse 1.2s ease-in-out infinite; }
</style>
